# ==================== DATABASE ====================
DATABASE_URL=mysql://root:password@localhost:3306/openhouse

# ==================== AUTH ====================
AUTH_SECRET=generate-me-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
PUBLIC_CHAT_COOKIE_SECRET=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Optional: dedicated encryption key for stored Google/Microsoft mailbox refresh tokens.
# If omitted, OpenHouse falls back to AUTH_SECRET.
MAIL_TOKEN_ENCRYPTION_KEY=

# Microsoft Entra / Outlook OAuth
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
# Optional. If omitted, OpenHouse defaults to the common tenant.
AUTH_MICROSOFT_ENTRA_ID_ISSUER=
# Optional convenience alias if you prefer building the issuer from a tenant ID.
MICROSOFT_TENANT_ID=

# ==================== STRIPE ====================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Pro Plan Price ID
STRIPE_PRO_PRICE_ID=price_xxx

# ==================== EMAIL ====================
# Used for system email and Pro custom sending domains.
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=OpenHouse <noreply@app.example.com>
RESEND_REPLY_TO_EMAIL=

# ==================== AI ====================
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
# Optional. Enables public-web lookups for property Q&A when MLS/flyer data is incomplete.
TAVILY_API_KEY=
# Optional allowlists for safer public-web grounding.
PROPERTY_QA_WEB_SEARCH_INCLUDE_DOMAINS=
PROPERTY_QA_SCHOOL_SEARCH_DOMAINS=
PROPERTY_QA_TRANSIT_SEARCH_DOMAINS=
PROPERTY_QA_TAX_SEARCH_DOMAINS=
PROPERTY_QA_NEIGHBORHOOD_SEARCH_DOMAINS=
# Optional. If provider address search misses, OpenHouse can build draft candidates from these public-web domains.
ADDRESS_IMPORT_WEB_SEARCH_INCLUDE_DOMAINS=

# ==================== LISTING IMPORT ====================
LISTING_DATA_API_URL=
LISTING_DATA_API_KEY=
LISTING_PROVIDER_BASE_URL=
LISTING_PROVIDER_API_KEY=
# Optional path overrides if your service differs from the default adapter.
LISTING_DATA_MLS_LOOKUP_PATH=/api/v1/listings/mls/:mlsId
LISTING_DATA_ADDRESS_SEARCH_PATH=/api/v1/search
# Legacy internal provider aliases are still supported for backward compatibility.
# Optional. Enables Google Places realtime address suggestions in Smart Import.
GOOGLE_MAPS_API_KEY=

# ==================== APP ====================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=OpenHouse Pro
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com
